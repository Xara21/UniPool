<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/unipool_yellow">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="48dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="70dp" />

        <!-- Logo -->

        <!-- Welcome -->

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="289dp"
            android:layout_height="105dp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:adjustViewBounds="true"
            android:contentDescription="UniPool Logo"
            android:src="@drawable/unipool_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:text="WELCOME DRIVER"
            android:textColor="@color/unipool_black"
            android:textSize="18sp"
            android:textStyle="bold" />


        <!-- Statistics -->

        <Button
            android:id="@+id/btnStatistics"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/unipool_black"
            android:text="📊 Statistics"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Departures -->

        <Button
            android:id="@+id/btnDepartures"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/unipool_black"
            android:text="🚌 Departures"
            android:textAllCaps="false"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Passengers -->

        <Button
            android:id="@+id/btnPassengers"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/unipool_black"
            android:text="👥 Passengers"
            android:textAllCaps="false"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Trip Logs -->

        <Button
            android:id="@+id/btnTripLogs"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/unipool_black"
            android:text="📜 Trip Logs"
            android:textAllCaps="false"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Messages -->

        <Button
            android:id="@+id/btnMessages"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/unipool_black"
            android:text="💬 Messages"
            android:textAllCaps="false"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Profile -->

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="50dp"
            android:backgroundTint="@color/unipool_black"
            android:text="👤 Profile"
            android:textAllCaps="false"
            android:textColor="@color/unipool_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <!-- Logout -->

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:backgroundTint="@color/unipool_white"
            android:text="🚪 Logout"
            android:textAllCaps="false"
            android:textColor="@color/unipool_black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>

</ScrollView>