<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_unipool"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Floating Menu -->

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMenu"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:contentDescription="Menu"
            android:src="@drawable/ic_menu_24"
            app:backgroundTint="@android:color/white"
            app:elevation="24dp"
            app:pressedTranslationZ="28dp"
            app:tint="@android:color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Main Card -->

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="18dp">

                <!-- Logo -->

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="140dp"
                    android:layout_height="40dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/unipool_logo"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Title -->

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="MESSAGES"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/imgLogo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Group Chats -->

                <TextView
                    android:id="@+id/txtGroups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="GROUP CHATS"
                    android:textColor="@android:color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/txtTitle"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Horizontal Tabs -->

                <HorizontalScrollView
                    android:id="@+id/hsvGroups"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fillViewport="false"
                    android:scrollbars="none"
                    app:layout_constraintTop_toBottomOf="@id/txtGroups"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:id="@+id/layoutGroups"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <!-- ================= SHUTTLE A ================= -->

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tabGroupA"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            app:cardBackgroundColor="#000000"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_shuttle"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Shuttle A"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- ================= SHUTTLE B ================= -->

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tabGroupB"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#DDDDDD"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_shuttle"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Shuttle B"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- ================= SHUTTLE C ================= -->

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tabGroupC"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="2dp"
                            app:strokeColor="#DDDDDD"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_shuttle"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Shuttle C"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- ================= CHAT HEADER ================= -->

                <androidx.cardview.widget.CardView
                    android:id="@+id/chatHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="3dp"
                    app:layout_constraintTop_toBottomOf="@id/hsvGroups"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chat_header"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:id="@+id/imgGroupIcon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_avatar_gray"
                            android:padding="8dp"
                            android:src="@drawable/ic_shuttle"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtGroupName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shuttle Group A"
                                android:textColor="@android:color/white"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/txtGroupStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="12 Members • Scheduled"
                                android:textColor="#DDDDDD"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_online"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>
                <!-- ================= MESSAGE AREA ================= -->

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/messageScroll"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="vertical"
                    app:layout_constraintTop_toBottomOf="@id/chatHeader"
                    app:layout_constraintBottom_toTopOf="@id/messageContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:id="@+id/layoutMessages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp"
                        android:paddingBottom="8dp">

                        <!-- Sample Messages -->

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                        <include layout="@layout/item_message_left"/>

                        <include layout="@layout/item_message_right"/>

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>
                <!-- ================= MESSAGE INPUT ================= -->

                <LinearLayout
                    android:id="@+id/messageContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Message Box -->

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMessage"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="3dp">

                        <EditText
                            android:id="@+id/etMessage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:hint="Type a message..."
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLines="4"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:textColor="@android:color/black"
                            android:textColorHint="#9E9E9E"
                            android:textSize="15sp"/>

                    </androidx.cardview.widget.CardView>

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp"/>

                    <!-- Send Button -->

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnSend"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:contentDescription="Send"
                        android:src="@android:drawable/ic_menu_send"
                        app:backgroundTint="#1976D2"
                        app:elevation="6dp"
                        app:tint="@android:color/white"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= NAVIGATION DRAWER ================= -->

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/white"
        app:headerLayout="@layout/nav_header_driver"
        app:itemIconTint="@null"
        app:menu="@menu/driver_drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>